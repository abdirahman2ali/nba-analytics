# Option 1: Full connection string (takes precedence)
# DATABASE_URL=postgresql://user:password@host:5432/nba_data?sslmode=require

# Option 2: Individual connection variables
PGHOST=localhost
PGPORT=5432
PGDATABASE=nba_data
PGUSER=your_username
PGPASSWORD=your_password

# Optional: set to 'require' for cloud databases like Neon
# PGSSLMODE=require
